<div class="page-content wrapper" data-section-id="{{ section.id }}" data-section-type="main-page">
  {% if section.settings.show_title and page.title != blank %}
    <h1 class="page-content__title {% if section.settings.title_align == 'center' %}text-center{% elsif section.settings.title_align == 'right' %}text-right{% endif %}">
      {{ page.title | escape }}
    </h1>
  {% endif %}

  {% if page.content != blank %}
    <div class="rte page-content__body">
      {{ page.content }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Page content",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show page title",
      "default": true
    },
    {
      "type": "select",
      "id": "title_align",
      "label": "Title alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    }
  ]
}
{% endschema %}
